импорт Основное
импорт Закупки
импорт Склад

@Обработчик
метод ПослеСоздания()
    ЗаполнитьКарточки()
;

метод ЗаполнитьКарточки()
    ЗаполнитьКарточкуЗаказов()
    ЗаполнитьКарточкуЗадач()
    ЗаполнитьКарточкуРеализаций()
    ЗаполнитьКарточкуНоменклатуры()
    ЗаполнитьТаблицуОстатков()
    ЗаполнитьСотрудников()
    ЗаполнитьДиаграммы()
;

метод ЗаполнитьДиаграммы()
    Компоненты.ДиаграммаОстатки.Источник.Данные = ПолучитьОстаткиПоСкладам()
    Компоненты.ДиаграммаВоронка.Источник.Данные = ПолучитьВоронкуПродаж()
    Компоненты.ДиаграммаЗаказы.Источник.Данные = ПолучитьЗаказыПоМесяцам()
    Компоненты.ДиаграммаЗадач.Значение = ПолучитьКоличествоЗадач()
;

метод ЗаполнитьКарточкуЗаказов()
    Компоненты.НадписьКоличествоЗаказов.Значение = ПолучитьКоличествоЗаказов().Представление()
;

метод ЗаполнитьКарточкуЗадач()
    Компоненты.НадписьКоличествоЗадач.Значение = ПолучитьКоличествоЗадач().Представление()
;

метод ЗаполнитьКарточкуРеализаций()
    Компоненты.НадписьКоличествоРеализаций.Значение = ПолучитьКоличествоРеализаций().Представление()
;

метод ЗаполнитьКарточкуНоменклатуры()
    Компоненты.НадписьКоличествоНоменклатуры.Значение = ПолучитьКоличествоНоменклатуры().Представление()
;

метод ЗаполнитьТаблицуОстатков()
    Компоненты.ТаблицаОстатков.Источник.Данные = ПолучитьОстатки()
;

метод ЗаполнитьСотрудников()
    Компоненты.СписокСотрудников.Источник.Данные = ПолучитьСотрудников()
;

метод БентоЗаказыПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    ЗаказКлиентаФормаСписка.Открыть()
;

метод БентоКонтрагентыПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    КонтрагентыФормаСписка.Открыть()
;

метод БентоНоменклатураПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    НоменклатураФормаСписка.Открыть()
;

метод БентоКатегорииПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    КатегорииТоваровФормаСписка.Открыть()
;

метод КарточкаЗаказовПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    ЗаказКлиентаФормаСписка.Открыть()
;

метод КарточкаЗадачПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    ЗадачиФормаСписка.Открыть()
;

метод КарточкаНоменклатурыПриНажатии(Источник: Карточка, Событие: СобытиеПриНажатии)
    НоменклатураФормаСписка.Открыть()
;

метод СоздатьЗаказПриНажатии(Команда: ОбычнаяКоманда)
    ЗаказКлиентаФормаОбъекта.Открыть(СпособОткрытия = СпособОткрытияФормы.ВДиалоговомОкне)
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьКоличествоЗаказов(): Число
    знч Запрос = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            ЗаказКлиента
    }
    возврат Запрос.Выполнить().Единственный().Количество
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьКоличествоЗадач(): Число
    знч Запрос = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            Задачи
    }
    возврат Запрос.Выполнить().Единственный().Количество
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьКоличествоРеализаций(): Число
    знч Запрос = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            Реализация
    }
    возврат Запрос.Выполнить().Единственный().Количество
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьКоличествоНоменклатуры(): Число
    знч Запрос = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            Номенклатура
    }
    возврат Запрос.Выполнить().Единственный().Количество
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьОстатки(): Массив<СтрокаОстатков>
    знч Результат = новый Массив<СтрокаОстатков>()
    знч Запрос = Запрос{
        ВЫБРАТЬ
            ТаблицаОстатков.Номенклатура.Наименование.ЗаменитьNull() КАК Наименование,
            ТаблицаОстатков.КоличествоОстаток КАК Количество
        ИЗ
            Остатки.Остатки() КАК ТаблицаОстатков
        УПОРЯДОЧИТЬ ПО
            Количество УБЫВ
    }
    для Строка из Запрос.Выполнить()
        Результат.Добавить(новый СтрокаОстатков(Наименование = Строка.Наименование, Количество = Строка.Количество))
    ;
    возврат Результат
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьСотрудников(): Массив<СтрокаСотрудника>
    знч Результат = новый Массив<СтрокаСотрудника>()
    знч Запрос = Запрос{
        ВЫБРАТЬ
            Наименование,
            Фото
        ИЗ
            Сотрудники
        УПОРЯДОЧИТЬ ПО
            Наименование
    }
    для Строка из Запрос.Выполнить()
        Результат.Добавить(новый СтрокаСотрудника(Наименование = Строка.Наименование, Фото = Строка.Фото))
    ;
    возврат Результат
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьОстаткиПоСкладам(): Массив<СтрокаОстатков>
    знч Результат = новый Массив<СтрокаОстатков>()
    знч Запрос = Запрос{
        ВЫБРАТЬ
            ТаблицаОстатков.Склад.Наименование.ЗаменитьNull() КАК Наименование,
            СУММА(ТаблицаОстатков.КоличествоОстаток) КАК Количество
        ИЗ
            Остатки.Остатки() КАК ТаблицаОстатков
        СГРУППИРОВАТЬ ПО
            ТаблицаОстатков.Склад.Наименование
        УПОРЯДОЧИТЬ ПО
            Количество УБЫВ
    }
    для Строка из Запрос.Выполнить()
        Результат.Добавить(новый СтрокаОстатков(Наименование = Строка.Наименование, Количество = Строка.Количество))
    ;
    возврат Результат
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьВоронкуПродаж(): Массив<СтрокаЭтапаПродаж>
    знч Результат = новый Массив<СтрокаЭтапаПродаж>()
    знч ЗапросЗаказов = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            ЗаказКлиента
    }
    знч ЗапросРеализаций = Запрос{
        ВЫБРАТЬ
            КОЛИЧЕСТВО(*) КАК Количество
        ИЗ
            Реализация
    }
    Результат.Добавить(новый СтрокаЭтапаПродаж(Этап = "Заказы", Количество = ЗапросЗаказов.Выполнить().Единственный().Количество))
    Результат.Добавить(новый СтрокаЭтапаПродаж(Этап = "Реализации", Количество = ЗапросРеализаций.Выполнить().Единственный().Количество))
    возврат Результат
;

@НаСервере @ДоступноСКлиента
статический метод ПолучитьЗаказыПоМесяцам(): Массив<СтрокаЗаказовПоМесяцу>
    знч Результат = новый Массив<СтрокаЗаказовПоМесяцу>()
    знч Запрос = Запрос{
        ВЫБРАТЬ
            Зк.Организация КАК Месяц,
            СУММА(Зк.Сумма) КАК Сумма
        ИЗ
            ЗаказКлиента КАК Зк
        СГРУППИРОВАТЬ ПО
            Зк.Организация
        УПОРЯДОЧИТЬ ПО
            Сумма УБЫВ
    }
    для Строка из Запрос.Выполнить()
        Результат.Добавить(новый СтрокаЗаказовПоМесяцу(Месяц = Строка.Месяц, Сумма = Строка.Сумма))
    ;
    возврат Результат
;
